// LỊM DONUTS — ERD

Table users {
  id objectid [primary key]
  username varchar [unique, not null]
  email varchar [unique, not null]
  password varchar [not null]
  role varchar
  phone varchar
  address varchar
  avatar varchar
  stars integer
  birthday date
  birthday_update_count integer
  referral_code varchar [unique]
  referred_by objectid
  tier_id objectid
  reset_otp varchar
  reset_otp_expiry timestamp
  created_at timestamp
}

Table user_favorites {
  user_id objectid [not null]
  product_id integer [not null]
}

Table user_stars_history {
  id objectid [primary key]
  user_id objectid [not null]
  amount integer
  reason varchar
  at timestamp
}

Table products {
  id integer [primary key]
  name varchar [not null]
  description text
  price varchar [not null]
  base_price varchar
  rating integer
  reviews varchar
  image varchar
  categories varchar
  labels varchar
  dietary varchar
  allergens varchar
  sold integer
  stock integer
  calories integer
  sugar integer
  fat integer
  protein integer
  flash_sale_discount_percent integer
  flash_sale_day_of_week integer
  flash_sale_start_hour integer
  flash_sale_end_hour integer
}

Table product_toppings {
  product_id integer [not null]
  name varchar
  price varchar
}

Table orders {
  id objectid [primary key]
  order_id varchar [unique, not null]
  user_id objectid
  total_amount integer
  order_type varchar
  deposit_percent integer
  deposit_amount integer
  remaining_amount integer
  deposit_paid boolean
  delivery_method varchar
  payment_method varchar
  payment_status varchar
  voucher_code varchar
  voucher_discount integer
  referral_discount integer
  stars_used integer
  custom_party_meta text
  cancel_deadline timestamp
  evidence_photo_url varchar
  status varchar
  created_at timestamp
}

Table order_customer_info {
  order_id objectid [primary key]
  name varchar
  phone varchar
  address varchar
  delivery_time varchar
  notes text
  is_gift boolean
  gift_message text
  hide_gift_price boolean
}

Table order_items {
  order_id objectid [not null]
  product_id integer
  name varchar
  price integer
  quantity integer
  options text
}

Table order_status_history {
  order_id objectid [not null]
  status varchar
  at timestamp
  changed_by objectid
}

Table reviews {
  id objectid [primary key]
  product_id integer [not null]
  user_id objectid
  user_name varchar
  rating integer [not null]
  comment text [not null]
  created_at timestamp
}

Table vouchers {
  id objectid [primary key]
  code varchar [unique, not null]
  type varchar [not null]
  value integer [not null]
  min_order_value integer
  max_discount integer
  expires_at timestamp
  usage_limit integer
  used_count integer
  active boolean
  created_at timestamp
}

Table complaints {
  id objectid [primary key]
  order_id objectid [not null]
  order_code varchar [not null]
  reason varchar [not null]
  description text
  photo_url varchar
  status varchar
  created_at timestamp
}

Table contact_messages {
  id objectid [primary key]
  full_name varchar [not null]
  email varchar [not null]
  phone varchar
  branch varchar
  subject varchar
  message text [not null]
  status varchar
  created_at timestamp
}

Table payments {
  id objectid [primary key]
  order_id objectid [not null]
  payment_type varchar [not null]
  amount integer [not null]
  method varchar
  status varchar
  transaction_ref varchar
  paid_at timestamp
  confirmed_by objectid
  created_at timestamp
}

Table refunds {
  id objectid [primary key]
  order_id objectid [not null]
  payment_id objectid
  reason varchar [not null]
  refund_amount integer [not null]
  refund_percent integer
  approved_by objectid
  status varchar
  requested_at timestamp
  processed_at timestamp
}

Table membership_tiers {
  id objectid [primary key]
  name varchar [not null]
  min_stars_earned integer
  star_multiplier integer
  benefits text
}

Table staff {
  id objectid [primary key]
  user_id objectid
  full_name varchar [not null]
  role varchar [not null]
  branch_id objectid
  active boolean
  created_at timestamp
}

Table branches {
  id objectid [primary key]
  name varchar [not null]
  address varchar [not null]
  phone varchar
  map_embed varchar
  open_hours varchar
  active boolean
}

Table complaint_resolutions {
  id objectid [primary key]
  complaint_id objectid [not null]
  resolution_type varchar
  note text
  handled_by objectid
  resolved_at timestamp
}

// ================= QUAN HỆ =================

Ref: users.referred_by > users.id

Ref: user_favorites.user_id > users.id
Ref: user_favorites.product_id > products.id
Ref: user_stars_history.user_id > users.id
Ref: orders.user_id > users.id
Ref: reviews.user_id > users.id

Ref: product_toppings.product_id > products.id
Ref: order_items.product_id > products.id
Ref: reviews.product_id > products.id

Ref: order_customer_info.order_id - orders.id
Ref: order_items.order_id > orders.id
Ref: order_status_history.order_id > orders.id
Ref: complaints.order_id > orders.id

Ref: orders.voucher_code > vouchers.code

Ref: payments.order_id > orders.id
Ref: payments.confirmed_by > staff.id
Ref: refunds.order_id > orders.id
Ref: refunds.payment_id > payments.id
Ref: refunds.approved_by > staff.id
Ref: users.tier_id > membership_tiers.id
Ref: staff.user_id > users.id
Ref: staff.branch_id > branches.id
Ref: order_status_history.changed_by > staff.id
Ref: complaint_resolutions.complaint_id > complaints.id
Ref: complaint_resolutions.handled_by > staff.id
